# Turso (libSQL) — get from https://app.turso.tech
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Dev: http://localhost:5173 — Prod: https://your-domain
BETTER_AUTH_URL=http://localhost:5173

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vercel Blob — provision at Vercel dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=

# Email domain allowlist for sign-in
ALLOWED_EMAIL_DOMAIN=vandaleradio.org
