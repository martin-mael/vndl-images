{
	"name": "@vandale/halftone",
	"version": "0.1.0",
	"description": "Halftone image effect React component",
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"publishConfig": {
		"main": "./dist/index.js",
		"module": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch"
	},
	"files": ["dist", "src"],
	"peerDependencies": {
		"react": ">=18"
	},
	"devDependencies": {
		"@types/react": "^19",
		"esbuild": ">=0.17",
		"tsup": "^8",
		"typescript": "^5"
	}
}
